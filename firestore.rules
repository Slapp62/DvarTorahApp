rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function currentRole() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function currentUserData() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : null;
    }

    function isAdmin() {
      return currentRole() == 'admin'
        || (currentUserData() != null && currentUserData().admin == true);
    }

    function isWriter() {
      return currentRole() == 'writer'
        || (currentUserData() != null && currentUserData().writer == true)
        || isAdmin();
    }

    function publishedDvar() {
      return resource.data.status == 'published';
    }

    match /users/{uid} {
      allow read: if signedIn();

      allow create: if isSelf(uid)
        && request.resource.data.role == 'viewer'
        && request.resource.data.admin == false
        && request.resource.data.writer == false
        && request.resource.data.viewer == false;

      allow update: if (
          isSelf(uid)
          && request.resource.data.role == resource.data.role
          && request.resource.data.admin == resource.data.admin
          && request.resource.data.writer == resource.data.writer
          && request.resource.data.viewer == resource.data.viewer
        ) || isAdmin();

      allow delete: if isSelf(uid);
    }

    match /divrei_torah/{dvarId} {
      allow read: if publishedDvar()
        || (signedIn() && resource.data.authorUid == request.auth.uid)
        || isAdmin();

      allow create: if isWriter()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.status == 'published';

      allow update: if (
          isWriter()
          && resource.data.authorUid == request.auth.uid
          && request.resource.data.authorUid == resource.data.authorUid
          && request.resource.data.authorName == resource.data.authorName
          && request.resource.data.status == resource.data.status
        ) || isAdmin();

      allow delete: if (
          isWriter()
          && resource.data.authorUid == request.auth.uid
        ) || isAdmin();

      match /likes/{uid} {
        allow read: if signedIn();
        allow create, delete: if isSelf(uid);
        allow update: if false;
      }
    }

    match /writer_applications/{applicationId} {
      allow read: if isAdmin() || (signedIn() && resource.data.applicantUid == request.auth.uid);

      allow create: if signedIn()
        && request.resource.data.applicantUid == request.auth.uid
        && request.resource.data.status == 'pending';

      allow update: if (
          signedIn()
          && resource.data.applicantUid == request.auth.uid
          && resource.data.status == 'rejected'
          && request.resource.data.applicantUid == resource.data.applicantUid
          && request.resource.data.applicantEmail == resource.data.applicantEmail
          && request.resource.data.applicantName == resource.data.applicantName
          && request.resource.data.status == 'pending'
        ) || isAdmin();

      allow delete: if isAdmin() || (
          signedIn() && resource.data.applicantUid == request.auth.uid
        );
    }

    match /reports/{reportId} {
      allow read: if isAdmin();

      allow create: if signedIn()
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.status == 'pending';

      allow update: if isAdmin();
      allow delete: if isAdmin()
        || (signedIn() && resource.data.reporterUid == request.auth.uid)
        || (signedIn() && resource.data.dvarAuthorUid == request.auth.uid);
    }

    match /external_submissions/{submissionId} {
      allow read, update, delete: if isAdmin();
      allow create: if isAdmin();
    }
  }
}
